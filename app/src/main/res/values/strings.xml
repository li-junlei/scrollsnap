    <string name="tutorial_title">Floating Ball Tutorial</string>
    <string name="tutorial_intro">Review the basics once to avoid interruptions during your first capture.</string>
    <string name="tutorial_ball_title">1. Position and purpose</string>
    <string name="tutorial_ball_desc">The floating ball appears on screen edge. Drag it to avoid blocking content. Tap it to start auto-scroll capture.</string>
    <string name="tutorial_start_title">2. Start capture</string>
    <string name="tutorial_start_desc">Tap the floating ball to start. Dragging the ball only repositions it and will not start capture.</string>
    <string name="tutorial_stop_title">3. Stop capture</string>
    <string name="tutorial_stop_desc">During capture, double-tap the transparent top 20% area of the screen, or press back. The app exits safely after the current cycle.</string>
    <string name="tutorial_tile_title">4. Quick settings tile</string>
    <string name="tutorial_tile_desc">In Quick Settings, tap ScrollSnap to toggle the floating ball. Long press opens the app directly.</string>
    <string name="tutorial_dont_show_again">Do not show this tutorial again</string>
